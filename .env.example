# Desert Rose Gives environment variables.

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.desertrosegives.org

# PayPal donation page URL.
# Set this to the production PayPal donate URL for Desert Rose Gives.
# If unset, the Donate button falls back to a generic PayPal donate form
# that pre-fills the Desert Rose Gives hello@ email as business.
NEXT_PUBLIC_PAYPAL_DONATE_URL=

# Contact form destination (used by /api/contact if server wiring is added).
CONTACT_EMAIL=hello@desertrosegives.org

# Newsletter provider credentials (to be set when provider is selected).
# EMAIL_SERVICE_PROVIDER=
# EMAIL_SERVICE_API_KEY=

# Analytics provider identifier (to be set when provider is selected).
# ANALYTICS_PROVIDER=
